# PDF Sanitizer Configuration
# Copy this file to .env and adjust values as needed

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Default output directory
OUTPUT_DIR=./output

# Chunk size for text splitting (words)
CHUNK_SIZE=500

# Overlap size for text chunks (words)
CHUNK_OVERLAP=50

# Enable OCR for scanned PDFs (requires markitdown-ocr plugin)
ENABLE_OCR=false

# OpenAI API key for OCR (if ENABLE_OCR=true)
OPENAI_API_KEY=

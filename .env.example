# ============================================================
# PDF SANITIZER - CONFIGURACIÓN
# ============================================================
# Copia este archivo a .env y ajusta los valores según sea necesario
# ============================================================

# ============================================================
# LOGGING
# ============================================================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# SALIDA Y ALMACENAMIENTO
# ============================================================
# Directorio de salida por defecto
OUTPUT_DIR=./output

# Formato de salida: jsonl, metadata, markdown, both
OUTPUT_FORMAT=both

# ============================================================
# CHUNKING
# ============================================================
# Tamaño del chunk en palabras (aproximado)
CHUNK_SIZE=500

# Solapamiento entre chunks en palabras
CHUNK_OVERLAP=50

# Palabras mínimas por chunk (por debajo se descarta)
MIN_WORDS=200

# Chunker por defecto: heading, token, sentence
DEFAULT_CHUNKER=heading

# ============================================================
# EXTRACTORES (CHEFS)
# ============================================================
# Extractor por defecto:
#   - docling     (recomendado, mejor calidad)
#   - markitdown  (buen balance)
#   - pymupdf4llm (rápido)
#   - pdfplumber  (simple)
#   - unstructured (con OCR)
#   - tesseract   (OCR puro)
DEFAULT_EXTRACTOR=docling

# Habilitar OCR para PDFs escaneados (requiere tesseract)
ENABLE_OCR=false

# ============================================================
# PERFILES DE PROCESAMIENTO
# ============================================================
# Perfil por defecto:
#   - rulebook    (Manual del Jugador, DMG, etc.)
#   - adventure   (Módulos de aventura como Strahd)
#   - generic     (Genérico, sin LLM)
DEFAULT_PROFILE=rulebook

# ============================================================
# LLM / IA LOCAL (OLLAMA)
# ============================================================
# Modelos recomendados para Ollama:
#   - qwen2.5:1.5b   (rápido, 1.5B parámetros, ~1GB)
#   - qwen2.5:7b     (balance, 7B parámetros, ~4GB)
#   - phi3:mini      (rápido, 3.8B parámetros, ~2GB)
#   - llama3.2:3b    (buen balance, 3B parámetros)
#   - mistral:7b     (calidad, 7B parámetros)
#   - gemma2:2b      (rápido, 2B parámetros)
OLLAMA_MODEL=qwen2.5:1.5b

# URL de la API de Ollama (si está en otro host/puerto)
OLLAMA_BASE_URL=http://localhost:11434

# Habilitar/deshabilitar LLM por defecto
LLM_ENABLED=true

# Tamaño máximo de tokens para respuestas LLM
LLM_MAX_TOKENS=512

# Temperatura para generación LLM (0.0 - 1.0)
LLM_TEMPERATURE=0.3

# ============================================================
# LLM / IA REMOTA (OPENAI - OPCIONAL)
# ============================================================
# OpenAI API Key (para usar modelos de OpenAI)
# OPENAI_API_KEY=sk-...

# Modelo de OpenAI por defecto
OPENAI_MODEL=gpt-4o-mini

# URL base para OpenAI (útil para proxies o APIs compatibles)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# CACHÉ DE LLM
# ============================================================
# Habilitar caché de respuestas LLM (reduce llamadas)
LLM_CACHE_ENABLED=true

# Tamaño máximo del caché (número de respuestas)
LLM_CACHE_MAX_SIZE=1000

# ============================================================
# PROCESAMIENTO POR LOTE (BATCH)
# ============================================================
# Número máximo de workers paralelos
BATCH_MAX_WORKERS=4

# Directorio para logs de batch
BATCH_LOG_DIR=./logs

# ============================================================
# AVANZADO - COMPORTAMIENTO DEL PIPELINE
# ============================================================
# Saltar chunks con menos de MIN_WORDS (siempre)
# Usar profiling para medir rendimiento
ENABLE_PROFILING=false

# ============================================================
# DEPURACIÓN
# ============================================================
# Guardar archivos intermedios (raw, debug)
SAVE_INTERMEDIATE=false

# Verbose output
VERBOSE=false
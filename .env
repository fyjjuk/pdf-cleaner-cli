# ============================================================
# PDF SANITIZER - CONFIGURACIÓN LOCAL
# ============================================================

# Logging
LOG_LEVEL=INFO

# Output
OUTPUT_DIR=./output
OUTPUT_FORMAT=both

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_WORDS=200
DEFAULT_CHUNKER=heading

# Extractores
DEFAULT_EXTRACTOR=pymupdf4llm
ENABLE_OCR=false

# Perfiles
DEFAULT_PROFILE=rulebook

# LLM - Ollama
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434
LLM_ENABLED=true
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# Caché LLM
LLM_CACHE_ENABLED=true
LLM_CACHE_MAX_SIZE=1000

# Batch
BATCH_MAX_WORKERS=4
BATCH_LOG_DIR=./logs

# Depuración
ENABLE_PROFILING=false
SAVE_INTERMEDIATE=false
VERBOSE=false